ACCOUNTS=account1,account2,account3

CDP_PORT=9222
# SSH tunnel only: 127.0.0.1
# Tailscale direct access: 0.0.0.0, then restrict port 9222 with firewall.
LOGIN_CDP_HOST=127.0.0.1
# Internal relay port inside the all-in-one container. 3000 is recommended.
RELAY_PORT=3000
PROFILES_DIR=/data/chrome
RELAY_START=pnpm start:relay

USE_SAFE_RELAY=true
RELAY_PROFILE_NAME=active
CONFIG_PATH=config.yaml
RUN_ONCE=--once
